# Environment Variables — MaxShop Backend
# Salin file ini menjadi .env dan isi nilainya

PORT=3000
NODE_ENV=development

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti_password_anda
ADMIN_EMAIL=admin@maxshop.id

# JWT Secret (gunakan string random yang panjang!)
JWT_SECRET=ganti_dengan_string_random_sangat_panjang

# WhatsApp Admin Number (awali dengan kode negara, tanpa +)
WA_NUMBER=62895393870131

# Session Secret
SESSION_SECRET=ganti_juga_ini_dengan_random_string
